VITE_QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
VITE_QWEN_MODEL=qwen-plus
VITE_QWEN_API_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# 推荐：后端调用大模型（用于生产，不暴露密钥给浏览器）
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
QWEN_MODEL=qwen-plus
QWEN_API_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# 手机号去重接口（默认可不填，前端会回退到 /api/participants/check-phone）
VITE_PHONE_CHECK_ENDPOINT=/api/participants/check-phone

VITE_FINAL_SUBMIT_ENDPOINT=/api/final-submit
VITE_REDIRECT_URL=https://www.credamo.com/s/xxxxxx

# 后端服务配置
PORT=8787
BACKEND_PORT=8787
DATA_DIR=./data
# 可选：跨域时设置为前端域名，例如 http://127.0.0.1:5173
CORS_ORIGIN=
